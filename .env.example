# --- Telegram ---
# API_ID and API_HASH are entered in the UI login form (from my.telegram.org).
# Only the session name lives here.
TG_SESSION_NAME=user_session

# --- Local LLM (LM Studio or any OpenAI-compatible server) ---
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=not-needed
LLM_MODEL=local-model
LLM_TEMPERATURE=1.1

# --- Behaviour ---
REPLY_DELAY=4
MAX_HISTORY=500

# The persona. You can also edit this live from the UI.
SYSTEM_PROMPT=You are acting as me on Telegram. Keep replies short (1-2 sentences), casual, and a little sarcastic. Never apologize.

# --- Server ---
DATA_DIR=data
CORS_ORIGINS=http://localhost:5173
